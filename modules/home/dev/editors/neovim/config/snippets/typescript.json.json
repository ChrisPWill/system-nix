{
  "assert_never_def": {
    "body": [
      "export const assertNever = (x: never): never => {",
      "  throw new Error(`Unexpected object: ${x}`);",
      "};"
    ],
    "description": "Exhaustiveness checking for unions",
    "prefix": "assert_never_def"
  },
  "brand": {
    "body": "export type ${1:Name}Id = Brand<${2:string}, '${1:Name}Id'>;",
    "description": "Usage of a Branded Type",
    "prefix": "brand"
  },
  "brand_def": {
    "body": [
      "export type Brand<K, T> = K & { __brand: T };"
    ],
    "description": "Definition of Branded Types (Nominal Typing)",
    "prefix": "brand_def"
  },
  "const_enum_def": {
    "body": [
      "export const ${1:NAME} = {",
      "  ${2:KEY}: '${2:VALUE}',",
      "} as const;",
      "",
      "export type ${1:NAME} = (typeof ${1:NAME})[keyof typeof ${1:NAME}];"
    ],
    "description": "Modern 'as const' enum replacement",
    "prefix": "const_enum_def"
  },
  "data_container_class": {
    "body": [
      "export class DataContainer<T> {",
      "  #data: T[] = [];",
      "  #updatedAt: Date;",
      "",
      "  constructor(initial?: T[]) {",
      "    if (initial) this.#data = [...initial];",
      "    this.#updatedAt = new Date();",
      "  }",
      "",
      "  get lastUpdated(): Date {",
      "    return this.#updatedAt;",
      "  }",
      "",
      "  add(item: T): this {",
      "    this.#data.push(item);",
      "    this.#updatedAt = new Date();",
      "    return this;",
      "  }",
      "",
      "  getAll(): readonly T[] {",
      "    return Object.freeze([...this.#data]);",
      "  }",
      "}"
    ],
    "description": "Example boilerplate for a modern TypeScript class",
    "prefix": "data_container_class"
  },
  "debounce_def": {
    "body": [
      "/**",
      " * Delays invoking 'fn' until 'ms' milliseconds have passed since the last invocation.",
      " */",
      "export const debounce = <T extends (...args: any[]) => void>(fn: T, ms: number) => {",
      "  let timeoutId: ReturnType<typeof setTimeout>;",
      "  return (...args: Parameters<T>) => {",
      "    // If function is called before timer expires, clear the old timer",
      "    clearTimeout(timeoutId);",
      "    // Start a fresh timer for the most recent call",
      "    timeoutId = setTimeout(() => fn(...args), ms);",
      "  };",
      "};"
    ],
    "description": "Simple debounce utility with comments",
    "prefix": "debounce_def"
  },
  "deep_partial_def": {
    "body": [
      "export type DeepPartial<T> = {",
      "  [P in keyof T]?: T[P] extends (infer U)[]",
      "    ? DeepPartial<U>[]",
      "    : T[P] extends object",
      "    ? DeepPartial<T[P]>",
      "    : T[P];",
      "};"
    ],
    "description": "Deeply partial type utility",
    "prefix": "deep_partial_def"
  },
  "get_or_set": {
    "body": [
      "/**",
      " * Returns the value associated with the key, or sets it to the default if it doesn't exist.",
      " */",
      "export const getOrSet = <K, V>(map: Map<K, V>, key: K, defaultValue: V): V => {",
      "  if (!map.has(key)) map.set(key, defaultValue);",
      "  return map.get(key)!;",
      "};"
    ],
    "description": "Returns the value associated with the key, or sets it to the default if it doesn't exist",
    "prefix": "get_or_set_def"
  },
  "is_type_def": {
    "body": [
      "export const is${1:Type} = (value: unknown): value is ${1:Type} => {",
      "  return ${2:condition};",
      "};"
    ],
    "description": "Type predicate / Type guard definition",
    "prefix": "is_type_def"
  },
  "memoize": {
    "body": [
      "export const memoize = <T extends (...args: any[]) => any>(fn: T): T => {",
      "  const cache = new Map<string, ReturnType<T>>();",
      "  return ((...args: Parameters<T>) => {",
      "    const key = JSON.stringify(args);",
      "    if (cache.has(key)) return cache.get(key);",
      "    const result = fn(...args);",
      "    cache.set(key, result);",
      "    return result;",
      "  }) as T;",
      "};"
    ],
    "description": "A generic wrapper for caching function results",
    "prefix": "memoize"
  },
  "pipe_def": {
    "body": [
      "export const pipe = <T>(value: T, ...fns: Array<(arg: any) => any>): any =>",
      "  fns.reduce((acc, fn) => fn(acc), value);"
    ],
    "description": "Functional pipe utility for chaining transformations",
    "prefix": "pipe_def"
  },
  "result_def": {
    "body": [
      "export type Result<T, E = Error> = ",
      "  | { ok: true; value: T }",
      "  | { ok: false; error: E };",
      "",
      "export const success = <T>(value: T): Result<T, never> => ({ ok: true, value });",
      "export const failure = <E>(error: E): Result<never, E> => ({ ok: false, error });"
    ],
    "description": "Result type pattern definition for error handling",
    "prefix": "result_def"
  },
  "sleep": {
    "body": [
      "export const sleep = (ms: number) => ",
      "  new Promise((resolve) => setTimeout(resolve, ms));"
    ],
    "description": "Standard sleep helper",
    "prefix": "sleep"
  },
  "with_timeout": {
    "body": [
      "export const withTimeout = <T>(promise: Promise<T>, ms: number): Promise<T> => {",
      "  const timeout = new Promise<never>((_, reject) => ",
      "    setTimeout(() => reject(new Error('Timed out')), ms),",
      "  );",
      "  return Promise.race([promise, timeout]);",
      "};"
    ],
    "description": "Promise timeout wrapper",
    "prefix": "with_timeout"
  }
}