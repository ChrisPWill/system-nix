#!/usr/bin/env nu

# ---
# Fetches the root dir of a repo regardless of whether it's jujutsu or git
# ---

let jjRoot = (do -i { jj root err> /dev/null } | str trim)
let gitRoot = (do -i { git rev-parse --show-toplevel err> /dev/null } | str trim)

let repoRoot = if ($jjRoot | is-not-empty) { $jjRoot } else if ($gitRoot | is-not-empty) { $gitRoot } else null

$repoRoot
