#!/usr/bin/env nu

# ---
# Toggles a pinned application between the 'pinned' workspace (tiled)
# and the current workspace (floating).
# ---

def find_target [app_id: string] {
    let windows = (niri msg --json windows | from json)
    ($windows | where {|w| ( ($w.app_id? | default "" | str contains -i $app_id) ) } | first)
}

def main [app_id: string, invoke_command: string, floating: bool = true] {
    let pinnedWorkspace = niri msg --json workspaces | from json | where name == "pinned" | get 0
    mut target = find_target $app_id

    if ($target | is-empty) {
        # App not running, start it
        ^niri msg action spawn -- $invoke_command
    }

    if $target.workspace_id != $pinnedWorkspace.id {
        # Return to the "pinned" workspace
        ^niri msg action move-window-to-workspace "pinned" --window-id $target.id --focus false
        ^niri msg action move-window-to-tiling --id $target.id
    } else {
        # Pull the window to the current workspace
        let workspaces = (niri msg --json workspaces | from json)
        let current_ws = ($workspaces | where is_focused | first)
        let outputs = (niri msg --json outputs | from json)
        let current_output = ($outputs | get $current_ws.output)
        
        let target_width = ($current_output.logical.width * 0.8 | into int)
        let target_height = ($current_output.logical.height * 0.8 | into int)

        if ($floating) {
            ^niri msg action move-window-to-floating --id $target.id
        }
        ^niri msg action set-window-width $target_width --id $target.id
        ^niri msg action set-window-height $target_height --id $target.id
        sleep 0.05sec # Quick sleep to give time for resize animation
        
        # Pull without following focus to stay on the current workspace
        ^niri msg action move-window-to-workspace ($current_ws.idx | into string) --window-id $target.id --focus false
        ^niri msg action focus-window --id $target.id
        ^niri msg action center-column
    }
}
