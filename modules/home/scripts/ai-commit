#!/usr/bin/env nu

def main [
  --print-prompt # Print the final prompt sent to the AI and exit
  --print-json # Print raw JSON responses from ai-ask while generating commit messages
] {
  let is_git = (".git" | path exists)
  let is_jj = (".jj" | path exists)

  if not ($is_git or $is_jj) {
    print -e "Error: Not a git or jj repository."
    exit 1
  }

  let has_gum = (which gum | is-not-empty)
  if not $has_gum {
    print -e "Error: 'gum' is not installed."
    exit 1
  }

  let has_ai = (which ai-ask | is-not-empty)
  if not $has_ai {
    print -e "Error: 'ai-ask' wrapper is not in PATH."
    exit 1
  }

  mut final_context = ""

  if $is_jj {
    let stat_out = (^jj diff --stat | complete).stdout
    let lines = ($stat_out | lines)
    mut diff_args = []
    mut excluded_files = []

    for line in $lines {
      if (($line | str contains "insertions") or ($line | str contains "deletions")) { continue }
      let parts = ($line | split row " | ")
      if ($parts | length) < 2 { continue }
      let file = ($parts.0 | str trim)
      let lines_changed = (try { $parts.1 | str trim | split row " " | get 0 | into int } catch { 0 })
      
      # TODO: Also exclude complete deletions and file moves
      if $lines_changed > 1000 {
        $excluded_files = ($excluded_files | append $file)
      } else {
        $diff_args = ($diff_args | append $file)
      }
    }

    let diff_content = if ($diff_args | is-empty) {
      ""
    } else {
      (^jj diff --git ...$diff_args | complete).stdout
    }

    let status_content = (^jj st | complete).stdout
    $final_context = $"STATUS:\n($status_content)\n\nDIFF:\n($diff_content)\n"

    if ($excluded_files | is-not-empty) {
      let excluded_str = ($excluded_files | str join ", ")
      $final_context = $"($final_context)\n\n[NOTE]: The following files were modified but their diffs are excluded from the prompt because they are too large (>1000 lines): ($excluded_str)"
    }
  } else {
    # git
    let staged = (^git diff --cached --name-only | complete)
    if ($staged.stdout | is-empty) {
      # Try gum confirm
      let confirm_res = (try { ^gum confirm "Nothing is staged. Stage all changes (git add .)?"; 0 } catch { 1 })
      if $confirm_res != 0 {
        print "Aborting."
        exit 0
      }
      ^git add .
    }

    let numstat = (^git diff --cached --numstat | complete)
    let lines = ($numstat.stdout | lines)
    mut diff_args = []
    mut excluded_files = []

    for line in $lines {
      if ($line | is-empty) { continue }
      let parts = ($line | split row "\t")
      let added = (if $parts.0 == "-" { 0 } else { $parts.0 | into int })
      let deleted = (if $parts.1 == "-" { 0 } else { $parts.1 | into int })
      let file = $parts.2

      if ($added + $deleted) > 1000 {
        $excluded_files = ($excluded_files | append $file)
      } else {
        $diff_args = ($diff_args | append $file)
      }
    }

    let diff_content = if ($diff_args | is-empty) {
      ""
    } else {
      (^git diff --cached -- ...$diff_args | complete).stdout
    }

    let status_content = (^git status | complete).stdout
    $final_context = $"STATUS:\n($status_content)\n\nDIFF:\n($diff_content)\n"

    if ($excluded_files | is-not-empty) {
      let excluded_str = ($excluded_files | str join ", ")
      $final_context = $"($final_context)\n\n[NOTE]: The following files were modified but their diffs are excluded from the prompt because they are too large (>1000 lines): ($excluded_str)"
    }
  }

  let system_prompt = "You are an expert software developer. Generate exactly 3 Git commit messages for the provided diff. Follow the Conventional Commits specification. Output ONLY a raw JSON array of objects, with no markdown blocks or other text.

Example format:
[
  {
    \"summary\": \"feat: <message>\",
    \"description\": \"<line1>\\n<line2>\"
  }
]

Each object must have a 'summary' field (the conventional commit title) and a 'description' field. The 'description' MUST be detailed and informative (typically 2-4 sentences or a short bulleted list), thoroughly explaining the 'why' and 'what' of the changes to give a reviewer full context. Do NOT include any ANSI escape codes, terminal control sequences, or backspace characters. IMPORTANT: You must escape all newlines inside JSON string values as \\n."

  if $print_prompt {
    print "=== SYSTEM PROMPT ==="
    print $system_prompt
    print "\n=== USER PROMPT (DIFF + STATUS) ==="
    print $final_context
    exit 0
  }

  mut parsed = []
  mut attempts = 0
  let max_attempts = 3

  while $attempts < $max_attempts {
    print ("Generating commit messages with AI (attempt " + ($attempts + 1 | into string) + ")...")

    let ai_stdout = (try { ai-ask $final_context --system $system_prompt } catch {
      print -e "Error running AI."
      exit 1
    })

    if $print_json {
      print "=== AI JSON RESPONSE ==="
      print $ai_stdout
    }

    let clean_json = ($ai_stdout | ansi strip | str replace -a "```json\n" "" | str replace -a "```\n" "" | str replace -a "```" "" | str trim)
    
    let try_parse = (try { $clean_json | from json } catch { null })

    if ($try_parse != null) and not ($try_parse | is-empty) {
      $parsed = $try_parse
      break
    } else {
      print -e "Error: Failed to parse AI output as JSON. Retrying..."
      if ($attempts == ($max_attempts - 1)) {
        print -e $"Raw output from final attempt:\n($ai_stdout)"
      }
      $attempts += 1
    }
  }

  if ($parsed | is-empty) {
    print -e "Error: AI failed to return valid JSON after multiple attempts."
    exit 1
  }

  # Clean the summaries to ensure they don't contain newlines, which breaks gum choose
  let parsed = ($parsed | each { |it| 
    let clean_sum = (try { $it.summary | str replace -a "\n" " " | str trim } catch { "" })
    $it | update summary $clean_sum 
  })

  let summaries = ($parsed | get summary)
  
  # Join with newlines and pipe to gum choose
  let chosen_summary = (try { $summaries | str join "\n" | ^gum choose | str trim } catch { "" })

  if ($chosen_summary | is-empty) {
    print "Aborted."
    exit 0
  }

  let selected_matches = ($parsed | where summary == $chosen_summary)
  if ($selected_matches | is-empty) {
    print -e "Error: Selected summary not found in parsed options."
    exit 1
  }
  
  let selected_obj = ($selected_matches | first)
  let full_message = $"($selected_obj.summary)\n\n($selected_obj.description)"

  if $is_jj {
    ^jj describe -m $full_message
  } else {
    ^git commit -m $full_message
  }
}
