#!/usr/bin/env nu

def clean-ai-json [ai_stdout: string] {
  $ai_stdout | ansi strip | str replace -a "```json\n" "" | str replace -a "```\n" "" | str replace -a "```" "" | str trim
}

def file-summary-system-prompt [] {
  "You are an expert software developer summarizing a single file change for commit message generation. Output concise plain text only, with no markdown block and no JSON. Summarize what changed in this file, why it likely changed when evident, and any behavior or integration impact. It is in git diff format, meaning lines starting with '-' are removed lines, and lines starting with '+' are added lines."
}

def summarize-file-change [file: string, diff_content: string] {
  let summary_prompt = (file-summary-system-prompt)
  let file_context = $"FILE: ($file)\n\nDIFF:\n($diff_content)"

  try {
    ai-ask $file_context --system $summary_prompt
  } catch {
    print -e $"Error running AI while summarizing ($file)."
    exit 1
  }
}

def print-commit-options [options: list<any>] {
  print "\n=== GENERATED COMMIT OPTIONS ==="
  print "Press Enter to retry, choose an option number, or type guidance to retry with a new hint:"
  print ""

  for option in ($options | enumerate) {
    let item = $option.item
    let summary = (try { $item.summary | str trim } catch { "" })
    let description = (try { $item.description | str trim } catch { "" })
    let option_number = ($option.index + 1)

    print $"($option_number). ($summary)"
    print $description
    print ""
  }
}

def build-final-context [
  status_content: string,
  hint: string,
  file_summaries: list<any>,
  excluded_files: list<any>,
  deleted_files: list<any>,
  include_deleted: bool
] {
  mut final_context = $"STATUS:\n($status_content)\n"

  if ($hint | str trim | is-not-empty) {
    $final_context = $"($final_context)\nHINT FOR COMMIT MESSAGE FROM USER:\n($hint | str trim)\n"
  }

  $final_context = $"($final_context)\nFILE SUMMARIES:\n"

  if ($file_summaries | is-empty) {
    $final_context = ($final_context + "(none)\n")
  } else {
    let joined_summaries = ($file_summaries | str join "\n\n")
    $final_context = $"($final_context)($joined_summaries)\n"
  }

  if ($excluded_files | is-not-empty) {
    let excluded_str = ($excluded_files | str join ", ")
    $final_context = $"($final_context)\n[NOTE]: The following files were modified but their diffs were not summarized because they are too large (>1000 lines): ($excluded_str)"
  }

  if (($deleted_files | is-not-empty) and not $include_deleted) {
    let deleted_str = ($deleted_files | str join ", ")
    $final_context = $"($final_context)\n[NOTE]: The following deleted files were not summarized by default: ($deleted_str)"
  }

  $final_context
}

def main [
  hint?: string # Optional guidance for the generated commit messages
  --print-prompt # Print the final prompt sent to the AI and exit
  --print-json # Print raw JSON responses from ai-ask while generating commit messages
  --include-deleted # Include deleted files in per-file AI summaries
] {
  let is_git = (".git" | path exists)
  let is_jj = (".jj" | path exists)

  if not ($is_git or $is_jj) {
    print -e "Error: Not a git or jj repository."
    exit 1
  }

  let has_gum = (which gum | is-not-empty)
  if not $has_gum {
    print -e "Error: 'gum' is not installed."
    exit 1
  }

  let has_ai = (which ai-ask | is-not-empty)
  if not $has_ai {
    print -e "Error: 'ai-ask' wrapper is not in PATH."
    exit 1
  }

  mut status_content = ""
  mut diff_args = []
  mut excluded_files = []
  mut deleted_files = []

  if $is_jj {
    let summary_out = (^jj diff --summary | complete).stdout
    for line in ($summary_out | lines) {
      if ($line | str trim | is-empty) { continue }
      let parts = ($line | str trim | split row " ")
      if (($parts | length) < 2) { continue }
      let status = ($parts | first)
      let file = ($parts | skip 1 | str join " ")

      if $status == "D" {
        $deleted_files = ($deleted_files | append $file)
      }
    }

    let stat_out = (^jj diff --stat | complete).stdout
    let lines = ($stat_out | lines)

    for line in $lines {
      if (($line | str contains "insertions") or ($line | str contains "deletions")) { continue }
      let parts = ($line | split row " | ")
      if ($parts | length) < 2 { continue }
      let file = ($parts.0 | str trim)
      let lines_changed = (try { $parts.1 | str trim | split row " " | get 0 | into int } catch { 0 })
      let is_deleted = ($deleted_files | any {|deleted| $deleted == $file })
      
      # Deleted files are listed in the final context, but are not summarized by default.
      if ($is_deleted and not $include_deleted) {
        continue
      } else if $lines_changed > 1000 {
        $excluded_files = ($excluded_files | append $file)
      } else {
        $diff_args = ($diff_args | append $file)
      }
    }

    $status_content = (^jj st | complete).stdout
  } else {
    # git
    let staged = (^git diff --cached --name-only | complete)
    if ($staged.stdout | is-empty) {
      # Try gum confirm
      let confirm_res = (try { ^gum confirm "Nothing is staged. Stage all changes (git add .)?"; 0 } catch { 1 })
      if $confirm_res != 0 {
        print "Aborting."
        exit 0
      }
      ^git add .
    }

    let name_status = (^git diff --cached --name-status | complete).stdout
    for line in ($name_status | lines) {
      if ($line | is-empty) { continue }
      let parts = ($line | split row "\t")
      if (($parts | length) < 2) { continue }
      let status = ($parts | first)
      let file = ($parts | last)

      if $status == "D" {
        $deleted_files = ($deleted_files | append $file)
      }
    }

    let numstat = (^git diff --cached --numstat | complete)
    let lines = ($numstat.stdout | lines)

    for line in $lines {
      if ($line | is-empty) { continue }
      let parts = ($line | split row "\t")
      let added = (if $parts.0 == "-" { 0 } else { $parts.0 | into int })
      let deleted = (if $parts.1 == "-" { 0 } else { $parts.1 | into int })
      let file = $parts.2
      let is_deleted = ($deleted_files | any {|deleted_file| $deleted_file == $file })

      if ($is_deleted and not $include_deleted) {
        continue
      } else if ($added + $deleted) > 1000 {
        $excluded_files = ($excluded_files | append $file)
      } else {
        $diff_args = ($diff_args | append $file)
      }
    }

    $status_content = (^git status | complete).stdout
  }

  let summary_prompt = (file-summary-system-prompt)

  if $print_prompt {
    print "=== FILE SUMMARY SYSTEM PROMPT ==="
    print $summary_prompt
    print "\n=== FILES TO SUMMARIZE ==="
    if ($diff_args | is-empty) {
      print "(none)"
    } else {
      print ($diff_args | str join "\n")
    }
  }

  let system_prompt = "You are an expert software developer. Generate exactly 3 Git commit messages for the provided repository status and per-file change summaries. Follow the Conventional Commits specification. Output ONLY a raw JSON array of objects, with no markdown blocks or other text.

Example format:
[
  {
    \"summary\": \"feat: <message>\",
    \"description\": \"<line1>\\n<line2>\"
  }
]

Each object must have a 'summary' field (the conventional commit title) and a 'description' field. The 'description' MUST be detailed and informative (typically 2-4 sentences or a short bulleted list), thoroughly explaining the 'why' and 'what' of the changes to give a reviewer full context. Do NOT include any ANSI escape codes, terminal control sequences, or backspace characters. IMPORTANT: You must escape all newlines inside JSON string values as \\n. Follow the hint from the user if possible."

  mut file_summaries = []

  if $print_prompt {
    for file in $diff_args {
      $file_summaries = ($file_summaries | append $"FILE: ($file)\nSUMMARY:\n<ai-generated summary would be inserted here>")
    }
  } else {
    for file in $diff_args {
      print $"Summarizing ($file) with AI..."
      let diff_content = if $is_jj {
        (^jj diff --git $file | complete).stdout
      } else {
        (^git diff --cached -- $file | complete).stdout
      }

      let summary = (summarize-file-change $file $diff_content | ansi strip | str trim)
      $file_summaries = ($file_summaries | append $"FILE: ($file)\nSUMMARY:\n($summary)")
    }
  }

  mut current_hint = ($hint | default "" | str trim)
  let final_context = (build-final-context $status_content $current_hint $file_summaries $excluded_files $deleted_files $include_deleted)

  if $print_prompt {
    print "\n=== FINAL JSON SYSTEM PROMPT ==="
    print $system_prompt
    print "\n=== FINAL USER PROMPT (STATUS + FILE SUMMARIES) ==="
    print $final_context
    exit 0
  }

  mut selected_obj = null

  while $selected_obj == null {
    let final_context = (build-final-context $status_content $current_hint $file_summaries $excluded_files $deleted_files $include_deleted)
    mut parsed = []
    mut attempts = 0
    let max_attempts = 3

    while $attempts < $max_attempts {
      print ("Generating commit messages with AI (attempt " + ($attempts + 1 | into string) + ")...")

      let ai_stdout = (try { ai-ask $final_context --system $system_prompt } catch {
        print -e "Error running AI."
        exit 1
      })

      if $print_json {
        print "=== AI JSON RESPONSE ==="
        print $ai_stdout
      }

      let clean_json = (clean-ai-json $ai_stdout)
      
      let try_parse = (try { $clean_json | from json } catch { null })

      if ($try_parse != null) and not ($try_parse | is-empty) {
        $parsed = $try_parse
        break
      } else {
        print -e "Error: Failed to parse AI output as JSON. Retrying..."
        if ($attempts == ($max_attempts - 1)) {
          print -e $"Raw output from final attempt:\n($ai_stdout)"
        }
        $attempts += 1
      }
    }

    if ($parsed | is-empty) {
      print -e "Error: AI failed to return valid JSON after multiple attempts."
      exit 1
    }

    # Clean the summaries to keep the generated option display compact.
    let parsed = ($parsed | each { |it| 
      let clean_sum = (try { $it.summary | str replace -a "\n" " " | str trim } catch { "" })
      $it | update summary $clean_sum 
    })

    print-commit-options $parsed

    let max_choice = ($parsed | length)
    let choice_input = (try { ^gum input --placeholder $"Enter retries; 1-($max_choice) chooses; text updates hint" --prompt "Option # or hint [retry]: " | str trim } catch { "" })

    if ($choice_input | is-empty) {
      continue
    }

    let choice = (try { $choice_input | into int } catch { null })

    if $choice == null {
      $current_hint = $choice_input
      print $"Using new hint: ($current_hint)"
      continue
    }

    if ($choice < 1) or ($choice > $max_choice) {
      print -e $"Error: Choose a number from 1 to ($max_choice)."
      continue
    }

    $selected_obj = ($parsed | get ($choice - 1))
  }

  let full_message = $"($selected_obj.summary)\n\n($selected_obj.description)"

  if $is_jj {
    ^jj describe -m $full_message
  } else {
    ^git commit -m $full_message
  }
}
