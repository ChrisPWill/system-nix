binds {
    // === System & Overview ===
    Super+Alt+Tab repeat=false { toggle-overview; }
    Super+Alt+Shift+Slash { show-hotkey-overlay; }

    // === Application Launchers ===
    Super+Alt+T hotkey-overlay-title="Open Terminal" { spawn "ghostty"; }
    Super+Alt+R hotkey-overlay-title="Application Launcher" { spawn "dms" "ipc" "call" "spotlight" "toggle"; }
    Super+Alt+B hotkey-overlay-title="Browser" { spawn "vivaldi"; }
    Super+Alt+V hotkey-overlay-title="Clipboard Manager" { spawn "dms" "ipc" "call" "clipboard" "toggle"; }
    Super+Alt+M hotkey-overlay-title="Task Manager" { spawn "dms" "ipc" "call" "processlist" "focusOrToggle"; }
    Super+Alt+Comma hotkey-overlay-title="Settings" { spawn "dms" "ipc" "call" "settings" "focusOrToggle"; }
    Super+Alt+Y hotkey-overlay-title="Browse Wallpapers" { spawn "dms" "ipc" "call" "dankdash" "wallpaper"; }
    Super+Alt+N hotkey-overlay-title="Notification Center" { spawn "dms" "ipc" "call" "notifications" "toggle"; }
    Super+Alt+Shift+N hotkey-overlay-title="Notepad" { spawn "dms" "ipc" "call" "notepad" "toggle"; }

    Super+Alt+P hotkey-overlay-title="Pinned Workspace" { focus-workspace "pinned"; }

    // === Caps Application Toggles ===
    Super+Alt+Shift+B hotkey-overlay-title="Open Btop" { spawn "ghostty" "--title=ghostty-floating" "-e" "btop"; }
    Super+Alt+Shift+Y hotkey-overlay-title="Open LazyJournal" { spawn "ghostty" "--title=ghostty-floating" "-e" "lazyjournal"; }
    Super+Alt+Ctrl+D hotkey-overlay-title="Toggle Discord" { spawn "toggle-pinned" "discord" "Discord"; }
    Super+Alt+Ctrl+S hotkey-overlay-title="Toggle Signal" { spawn "toggle-pinned" "signal" "signal-desktop"; }
    Super+Alt+O hotkey-overlay-title="Toggle Obsidian" { spawn "toggle-pinned" "electron" "obsidian" "Obsidian"; }
    Super+Alt+BackSlash hotkey-overlay-title="Toggle LogSeq" { spawn "toggle-pinned" "logseq" "logseq" "logseq"; }

    // === Security ===
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen" { spawn "dms" "ipc" "call" "lock" "lock"; }
    Super+Alt+Shift+Escape { quit; }
    Ctrl+Alt+Delete hotkey-overlay-title="Task Manager" { spawn "dms" "ipc" "call" "processlist" "focusOrToggle"; }

    // === Audio Controls ===
    XF86AudioRaiseVolume allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "increment" "3"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "decrement" "3"; }
    XF86AudioMute allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "mute"; }
    XF86AudioMicMute allow-when-locked=true { spawn "dms" "ipc" "call" "audio" "micmute"; }
    // === Media Controls ===
    XF86AudioPlay allow-when-locked=true { spawn "dms" "ipc" "call" "mpris" "playPause"; }
    XF86AudioStop allow-when-locked=true { spawn "dms" "ipc" "call" "mpris" "stop"; }
    XF86AudioNext allow-when-locked=true { spawn "dms" "ipc" "call" "mpris" "next"; }
    XF86AudioPrev allow-when-locked=true { spawn "dms" "ipc" "call" "mpris" "previous"; }

    // === Brightness Controls ===
    XF86MonBrightnessUp allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "increment" "5" ""; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "dms" "ipc" "call" "brightness" "decrement" "5" ""; }

    // === Window Management ===
    Super+Alt+BackSpace repeat=false { close-window; }
    Super+Alt+F { maximize-column; }
    Super+Alt+Shift+F { fullscreen-window; }
    Super+Alt+Shift+T { toggle-window-floating; }
    Super+Alt+Shift+V { switch-focus-between-floating-and-tiling; }
    Super+Alt+Ctrl+W { toggle-column-tabbed-display; }

    // === Focus Navigation ===
    Super+Alt+H     { focus-column-left; }
    Super+Alt+J     { focus-window-down; }
    Super+Alt+K     { focus-window-up; }
    Super+Alt+L     { focus-column-right; }
    Super+Alt+Left     { focus-column-left; }
    Super+Alt+Down     { focus-window-down; }
    Super+Alt+Up     { focus-window-up; }
    Super+Alt+Right     { focus-column-right; }

    // === Window Movement ===
    Super+Alt+Shift+Left  { move-column-left; }
    Super+Alt+Shift+Down  { move-window-down; }
    Super+Alt+Shift+Up    { move-window-up; }
    Super+Alt+Shift+Right { move-column-right; }
    Super+Alt+Shift+H     { move-column-left; }
    Super+Alt+Shift+J     { move-window-down; }
    Super+Alt+Shift+K     { move-window-up; }
    Super+Alt+Shift+L     { move-column-right; }
    Super+Alt+Ctrl+Shift+Left    { move-workspace-to-monitor-left; }
    Super+Alt+Ctrl+Shift+Right    { move-workspace-to-monitor-right; }

    // === Column Navigation ===
    Super+Alt+Home { focus-column-first; }
    Super+Alt+End  { focus-column-last; }
    Super+Alt+Ctrl+Home { move-column-to-first; }
    Super+Alt+Ctrl+End  { move-column-to-last; }

    // === Monitor Navigation ===
    Super+Alt+Ctrl+Left  { focus-monitor-left; }
    //Super+Alt+Ctrl+Down  { focus-monitor-down; }
    //Super+Alt+Ctrl+Up    { focus-monitor-up; }
    Super+Alt+Ctrl+Right { focus-monitor-right; }
    Super+Alt+Ctrl+H     { focus-monitor-left; }
    Super+Alt+Ctrl+J     { focus-monitor-down; }
    Super+Alt+Ctrl+K     { focus-monitor-up; }
    Super+Alt+Ctrl+L     { focus-monitor-right; }

    // === Move to Monitor ===
    Super+Alt+Shift+Ctrl+H     { move-column-to-monitor-left; }
    Super+Alt+Shift+Ctrl+J     { move-column-to-monitor-down; }
    Super+Alt+Shift+Ctrl+K     { move-column-to-monitor-up; }
    Super+Alt+Shift+Ctrl+L     { move-column-to-monitor-right; }

    // === Workspace Navigation ===
    Super+Alt+Page_Down      { focus-workspace-down; }
    Super+Alt+Page_Up        { focus-workspace-up; }
    Super+Alt+U              { focus-workspace-down; }
    Super+Alt+I              { focus-workspace-up; }
    Super+Alt+Ctrl+Down { move-column-to-workspace-down; }
    Super+Alt+Ctrl+Up   { move-column-to-workspace-up; }
    Super+Alt+Ctrl+U         { move-column-to-workspace-down; }
    Super+Alt+Ctrl+I         { move-column-to-workspace-up; }

    // === Move Workspaces ===
    Super+Alt+Shift+Page_Down { move-workspace-down; }
    Super+Alt+Shift+Page_Up   { move-workspace-up; }
    Super+Alt+Shift+U         { move-workspace-down; }
    Super+Alt+Shift+I         { move-workspace-up; }

    // === Mouse Wheel Navigation ===
    Super+Alt+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Super+Alt+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Super+Alt+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Super+Alt+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Super+Alt+WheelScrollRight      { focus-column-right; }
    Super+Alt+WheelScrollLeft       { focus-column-left; }
    Super+Alt+Ctrl+WheelScrollRight { move-column-right; }
    Super+Alt+Ctrl+WheelScrollLeft  { move-column-left; }

    Super+Alt+Shift+WheelScrollDown      { focus-column-right; }
    Super+Alt+Shift+WheelScrollUp        { focus-column-left; }
    Super+Alt+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Super+Alt+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // === Numbered Workspaces ===
    Super+Alt+1 { focus-workspace 1; }
    Super+Alt+2 { focus-workspace 2; }
    Super+Alt+3 { focus-workspace 3; }
    Super+Alt+4 { focus-workspace 4; }
    Super+Alt+5 { focus-workspace 5; }
    Super+Alt+6 { focus-workspace 6; }
    Super+Alt+7 { focus-workspace 7; }
    Super+Alt+8 { focus-workspace 8; }
    Super+Alt+9 { focus-workspace 9; }
    Super+Alt+Q { focus-workspace 10; }
    Super+Alt+W { focus-workspace 11; }
    Super+Alt+E { focus-workspace 12; }
    Super+Alt+A { focus-workspace 13; }
    Super+Alt+S { focus-workspace 14; }
    Super+Alt+D { focus-workspace 15; }

    // === Move to Numbered Workspaces ===
    Super+Alt+Shift+1 { move-column-to-workspace 1; }
    Super+Alt+Shift+2 { move-column-to-workspace 2; }
    Super+Alt+Shift+3 { move-column-to-workspace 3; }
    Super+Alt+Shift+4 { move-column-to-workspace 4; }
    Super+Alt+Shift+5 { move-column-to-workspace 5; }
    Super+Alt+Shift+6 { move-column-to-workspace 6; }
    Super+Alt+Shift+7 { move-column-to-workspace 7; }
    Super+Alt+Shift+8 { move-column-to-workspace 8; }
    Super+Alt+Shift+9 { move-column-to-workspace 9; }
    Super+Alt+Shift+Q { move-column-to-workspace 10; }
    Super+Alt+Shift+W { move-column-to-workspace 11; }
    Super+Alt+Shift+E { move-column-to-workspace 12; }
    Super+Alt+Shift+A { move-column-to-workspace 13; }
    Super+Alt+Shift+S { move-column-to-workspace 14; }
    Super+Alt+Shift+D { move-column-to-workspace 15; }

    // === Column Management ===
    Super+Alt+BracketLeft  { consume-or-expel-window-left; }
    Super+Alt+BracketRight { consume-or-expel-window-right; }
    Super+Alt+Period { expel-window-from-column; }

    // === Sizing & Layout ===
    Super+Alt+Space { switch-preset-column-width; }
    Super+Alt+Shift+Space { switch-preset-window-height; }
    Super+Alt+Ctrl+R { reset-window-height; }
    Super+Alt+Ctrl+F { expand-column-to-available-width; }
    Super+Alt+C { center-column; }
    Super+Alt+Ctrl+C { center-visible-columns; }

    // === Manual Sizing ===
    Super+Alt+Minus { set-column-width "-10%"; }
    Super+Alt+Equal { set-column-width "+10%"; }
    Super+Alt+Shift+Minus { set-window-height "-10%"; }
    Super+Alt+Shift+Equal { set-window-height "+10%"; }

    // === Screenshots ===
    XF86Launch1 { screenshot; }
    Ctrl+XF86Launch1 { screenshot-screen; }
    Alt+XF86Launch1 { screenshot-window; }
    Print { screenshot; }
    Ctrl+Print { screenshot-screen; }
    Alt+Print { screenshot-window; }
    // === System Controls ===
    Super+Alt+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
    Super+Alt+Shift+P { power-off-monitors; }
}
