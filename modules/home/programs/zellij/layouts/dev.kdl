layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="tab-bar"
    }
    children
    pane size=1 borderless=true {
      plugin location="status-bar"
    }
  }
  tab name="code" focus=true {
    pane edit="."

  }
  tab name="shells" {
    pane split_direction="vertical" {
      pane name="tests" command="nu"
      pane name="shell" command="nu"
    }
  }
  tab name="vcs" {
    pane command="open-vcs"
  }
  tab name="files" {
    pane command="yazi"
  }
}
