layout {
  // hide_floating_panes bugged with this, manually copied for now
  // default_tab_template  {
  //   pane size=1 borderless=true {
  //     plugin location="tab-bar"
  //   }
  //   children
  //   pane size=1 borderless=true {
  //     plugin location="status-bar"
  //   }
  // }
  tab name="code" focus=true hide_floating_panes=true {
    pane command="nvim" args="."
    floating_panes {
        pane name="Lint" command="fish" {
            x "2%"
            y "2%"
            width "48%"
            height "48%"
        }
        pane name="Shell" command="fish" {
            x "52%"
            y "2%"
            width "48%"
            height "48%"
        }
        pane name="Tests" command="fish" {
            x "2%"
            y "52%"
            width "48%"
            height "48%"
        }
        pane name="VCS" command="open-vcs" {
            x "52%"
            y "52%"
            width "48%"
            height "48%"
        }
    }
    pane size=1 borderless=true {
      plugin location="status-bar"
    }
  }
}
