layout {
  default_tab_template {
    pane size=1 borderless=true {
      plugin location="tab-bar"
    }
    children
    pane size=1 borderless=true {
      plugin location="status-bar"
    }
  }
  tab name="code" focus=true hide_floating_panes=true {
    pane edit="."

    floating_panes {
      pane name="tests" command="nu" {
        x 1
        width "50%"
      }
      pane name="shell" command="nu" {
        x "50%"
        width "50%"
      }
    }
  }
  tab name="vcs" {
    pane command="lazyjj"
  }
  tab name="files" {
    pane command="yazi"
  }
}
